<?php

/**
 * Google OAuth 2.0 — скопируйте в config/google.php и заполните ключи.
 *
 * Authorized redirect URI в Google Cloud Console:
 *   https://zakopeyki.kz/login
 */
return [
    'client_id' => getenv('GOOGLE_CLIENT_ID') ?: '',
    'client_secret' => getenv('GOOGLE_CLIENT_SECRET') ?: '',
    'redirect_uri' => getenv('GOOGLE_REDIRECT_URI') ?: 'https://zakopeyki.kz/login',
];
